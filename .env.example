# =========================================
# ORDER GATEWAY - Environment Configuration
# =========================================

# Server
PORT=3000
NODE_ENV=production

# API Key Authentication (shared secret between gateway and client apps)
# Generate a strong random string: openssl rand -hex 32
GATEWAY_API_KEY=change-me-use-a-strong-random-secret

# =========================================
# Zerodha Kite API
# =========================================
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret

# Token source: "env" (use KITE_ACCESS_TOKEN directly) or "service" (fetch from URL)
KITE_TOKEN_SOURCE=service
KITE_ACCESS_TOKEN=

# External token service URL (same as your existing apps)
TOKEN_SERVICE_URL=https://token-xdpxv.ondigitalocean.app/api/fetchToken

# Token auto-refresh time (HH:MM in IST, before market open)
TOKEN_REFRESH_TIME=08:05

# =========================================
# Database
# =========================================
# SQLite file path (relative or absolute)
DB_PATH=./data/orders.db

# =========================================
# Idempotency
# =========================================
# How long to remember idempotency keys (ms). Default: 5 minutes
IDEMPOTENCY_TTL_MS=300000

# =========================================
# Order Execution
# =========================================
# Maximum retries on transient Kite API failures (1 = one safe retry)
MAX_RETRIES=1

# Request timeout for Kite API calls (ms)
KITE_TIMEOUT_MS=5000

# =========================================
# CORS (comma-separated allowed origins)
# =========================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
