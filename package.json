{
  "name": "order-gateway",
  "version": "1.0.0",
  "description": "Centralized Order Execution Gateway for Zerodha Kite API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx --experimental-sqlite watch src/index.ts",
    "build": "tsc",
    "start": "node --experimental-sqlite dist/index.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "ui:dev": "cd ui && npm run dev",
    "ui:build": "cd ui && npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "kiteconnect": "^5.1.0",
    "node-fetch": "^3.3.2",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.19.15",
    "@types/node-fetch": "^2.6.11",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  }
}
